[fetch]
    prune = false
[pull]
    rebase = false
    ff = only
[rebase]
    autoStash = false
    autosquash = false
    updateRefs = false
[core]
    eol = lf
    autocrlf = false
    editor = nano
[i18n]
    filesEncoding = utf-8
[alias]
    shuffle = !git rebase -i --autosquash --autostash
    full = !git fetch --all && git pull
    branch = !git checkout -B
    kommit = !git add -p && git commit
    logo = !git log --pretty=oneline
    pfush = !git push --force-with-lease
    subsfix = !git submodule update --init --recursive --rebase && git status
    schmutz = !git reset --hard && git clean -dfx
    fullschmutz = !git reset --hard && git clean -dfx && git fetch --all && git pull
    back = !git restore *.* && git fetch --all && git pull
    linecount = !git ls-files | xargs wc -l
    checklf = !git ls-files --stage --eol
    make-exec = !git update-index --add --chmod=+x --really-refresh
    ff = !git fetch --all
    rr = !git reset --hard
    ll = !git logo

[diff]
        guitool = vscode
        tool = nano
[merge]
        guitool = vscode
        tool = nano
